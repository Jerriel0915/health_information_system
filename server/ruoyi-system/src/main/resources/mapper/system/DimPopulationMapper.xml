<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.DimPopulationMapper">
    
    <resultMap type="DimPopulation" id="DimPopulationResult">
        <result property="id"    column="id"    />
        <result property="regionId"    column="region_id"    />
        <result property="totalPopulation"    column="total_population"    />
        <result property="malePopulation"    column="male_population"    />
        <result property="femalePopulation"    column="female_population"    />
        <result property="age014"    column="age_0_14"    />
        <result property="age1559"    column="age_15_59"    />
        <result property="age60Plus"    column="age_60_plus"    />
        <result property="statYear"    column="stat_year"    />
        <result property="createdAt"    column="created_at"    />
    </resultMap>

    <sql id="selectDimPopulationVo">
        select id, region_id, total_population, male_population, female_population, age_0_14, age_15_59, age_60_plus, stat_year, created_at from dim_population
    </sql>

    <select id="selectDimPopulationList" parameterType="DimPopulation" resultMap="DimPopulationResult">
        <include refid="selectDimPopulationVo"/>
        <where>  
            <if test="regionId != null "> and region_id = #{regionId}</if>
            <if test="totalPopulation != null "> and total_population = #{totalPopulation}</if>
            <if test="malePopulation != null "> and male_population = #{malePopulation}</if>
            <if test="femalePopulation != null "> and female_population = #{femalePopulation}</if>
            <if test="age014 != null "> and age_0_14 = #{age014}</if>
            <if test="age1559 != null "> and age_15_59 = #{age1559}</if>
            <if test="age60Plus != null "> and age_60_plus = #{age60Plus}</if>
            <if test="statYear != null "> and stat_year = #{statYear}</if>
            <if test="createdAt != null "> and created_at = #{createdAt}</if>
        </where>
    </select>
    
    <select id="selectDimPopulationById" parameterType="Long" resultMap="DimPopulationResult">
        <include refid="selectDimPopulationVo"/>
        where id = #{id}
    </select>

    <insert id="insertDimPopulation" parameterType="DimPopulation" useGeneratedKeys="true" keyProperty="id">
        insert into dim_population
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="regionId != null">region_id,</if>
            <if test="totalPopulation != null">total_population,</if>
            <if test="malePopulation != null">male_population,</if>
            <if test="femalePopulation != null">female_population,</if>
            <if test="age014 != null">age_0_14,</if>
            <if test="age1559 != null">age_15_59,</if>
            <if test="age60Plus != null">age_60_plus,</if>
            <if test="statYear != null">stat_year,</if>
            <if test="createdAt != null">created_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="regionId != null">#{regionId},</if>
            <if test="totalPopulation != null">#{totalPopulation},</if>
            <if test="malePopulation != null">#{malePopulation},</if>
            <if test="femalePopulation != null">#{femalePopulation},</if>
            <if test="age014 != null">#{age014},</if>
            <if test="age1559 != null">#{age1559},</if>
            <if test="age60Plus != null">#{age60Plus},</if>
            <if test="statYear != null">#{statYear},</if>
            <if test="createdAt != null">#{createdAt},</if>
         </trim>
    </insert>

    <update id="updateDimPopulation" parameterType="DimPopulation">
        update dim_population
        <trim prefix="SET" suffixOverrides=",">
            <if test="regionId != null">region_id = #{regionId},</if>
            <if test="totalPopulation != null">total_population = #{totalPopulation},</if>
            <if test="malePopulation != null">male_population = #{malePopulation},</if>
            <if test="femalePopulation != null">female_population = #{femalePopulation},</if>
            <if test="age014 != null">age_0_14 = #{age014},</if>
            <if test="age1559 != null">age_15_59 = #{age1559},</if>
            <if test="age60Plus != null">age_60_plus = #{age60Plus},</if>
            <if test="statYear != null">stat_year = #{statYear},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteDimPopulationById" parameterType="Long">
        delete from dim_population where id = #{id}
    </delete>

    <delete id="deleteDimPopulationByIds" parameterType="String">
        delete from dim_population where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- ====== 统计分析查询 ====== -->

    <select id="selectPopulationSummary" resultType="java.util.Map">
        select
            coalesce(sum(total_population), 0) as totalPopulation,
            coalesce(sum(male_population), 0) as malePopulation,
            coalesce(sum(female_population), 0) as femalePopulation
        from dim_population
        <where>
            <if test="regionId != null"> and region_id = #{regionId} </if>
            <if test="year != null"> and stat_year = #{year} </if>
        </where>
    </select>

    <select id="selectPopulationAgeDistribution" resultType="java.util.Map">
        select
            coalesce(sum(age_0_14), 0) as age0_14,
            coalesce(sum(age_15_59), 0) as age15_59,
            coalesce(sum(age_60_plus), 0) as age60_plus
        from dim_population
        <where>
            <if test="regionId != null"> and region_id = #{regionId} </if>
            <if test="year != null"> and stat_year = #{year} </if>
        </where>
    </select>

    <select id="selectPopulationGenderRatio" resultType="java.util.Map">
        select
            coalesce(sum(male_population), 0) as maleCount,
            coalesce(sum(female_population), 0) as femaleCount
        from dim_population
        <where>
            <if test="regionId != null"> and region_id = #{regionId} </if>
            <if test="year != null"> and stat_year = #{year} </if>
        </where>
    </select>

    <select id="selectPopulationRegionDistribution" resultType="java.util.Map">
        select r.region_name as name, coalesce(sum(p.total_population), 0) as value
        from dim_population p
        join dim_region r on p.region_id = r.id
        <if test="year != null"> where p.stat_year = #{year} </if>
        group by r.region_name
        order by value desc
    </select>

    <select id="selectPopulationTrend" resultType="java.util.Map">
        select stat_year as year, coalesce(sum(total_population), 0) as value
        from dim_population
        group by stat_year
        order by stat_year
    </select>

</mapper>