<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.DimRegionMapper">
    
    <resultMap type="DimRegion" id="DimRegionResult">
        <result property="id"    column="id"    />
        <result property="regionCode"    column="region_code"    />
        <result property="regionName"    column="region_name"    />
        <result property="regionLevel"    column="region_level"    />
        <result property="parentId"    column="parent_id"    />
        <result property="sortOrder"    column="sort_order"    />
        <result property="createdAt"    column="created_at"    />
    </resultMap>

    <sql id="selectDimRegionVo">
        select id, region_code, region_name, region_level, parent_id, sort_order, created_at from dim_region
    </sql>

    <select id="selectDimRegionList" parameterType="DimRegion" resultMap="DimRegionResult">
        <include refid="selectDimRegionVo"/>
        <where>  
            <if test="regionCode != null  and regionCode != ''"> and region_code = #{regionCode}</if>
            <if test="regionName != null  and regionName != ''"> and region_name like concat('%', #{regionName}, '%')</if>
            <if test="regionLevel != null "> and region_level = #{regionLevel}</if>
            <if test="parentId != null "> and parent_id = #{parentId}</if>
            <if test="sortOrder != null "> and sort_order = #{sortOrder}</if>
            <if test="createdAt != null "> and created_at = #{createdAt}</if>
        </where>
    </select>
    
    <select id="selectDimRegionById" parameterType="Long" resultMap="DimRegionResult">
        <include refid="selectDimRegionVo"/>
        where id = #{id}
    </select>

    <insert id="insertDimRegion" parameterType="DimRegion" useGeneratedKeys="true" keyProperty="id">
        insert into dim_region
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="regionCode != null and regionCode != ''">region_code,</if>
            <if test="regionName != null and regionName != ''">region_name,</if>
            <if test="regionLevel != null">region_level,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="createdAt != null">created_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="regionCode != null and regionCode != ''">#{regionCode},</if>
            <if test="regionName != null and regionName != ''">#{regionName},</if>
            <if test="regionLevel != null">#{regionLevel},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="createdAt != null">#{createdAt},</if>
         </trim>
    </insert>

    <update id="updateDimRegion" parameterType="DimRegion">
        update dim_region
        <trim prefix="SET" suffixOverrides=",">
            <if test="regionCode != null and regionCode != ''">region_code = #{regionCode},</if>
            <if test="regionName != null and regionName != ''">region_name = #{regionName},</if>
            <if test="regionLevel != null">region_level = #{regionLevel},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteDimRegionById" parameterType="Long">
        delete from dim_region where id = #{id}
    </delete>

    <delete id="deleteDimRegionByIds" parameterType="String">
        delete from dim_region where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>