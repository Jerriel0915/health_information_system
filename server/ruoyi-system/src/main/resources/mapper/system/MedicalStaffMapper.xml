<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.MedicalStaffMapper">
    
    <resultMap type="MedicalStaff" id="MedicalStaffResult">
        <result property="id"    column="id"    />
        <result property="staffCode"    column="staff_code"    />
        <result property="staffName"    column="staff_name"    />
        <result property="gender"    column="gender"    />
        <result property="birthDate"    column="birth_date"    />
        <result property="orgId"    column="org_id"    />
        <result property="department"    column="department"    />
        <result property="jobTitle"    column="job_title"    />
        <result property="jobCategory"    column="job_category"    />
        <result property="education"    column="education"    />
        <result property="isActive"    column="is_active"    />
        <result property="entryDate"    column="entry_date"    />
        <result property="createdAt"    column="created_at"    />
        <result property="updatedAt"    column="updated_at"    />
    </resultMap>

    <sql id="selectMedicalStaffVo">
        select id, staff_code, staff_name, gender, birth_date, org_id, department, job_title, job_category, education, is_active, entry_date, created_at, updated_at from medical_staff
    </sql>

    <select id="selectMedicalStaffList" parameterType="MedicalStaff" resultMap="MedicalStaffResult">
        <include refid="selectMedicalStaffVo"/>
        <where>  
            <if test="staffCode != null  and staffCode != ''"> and staff_code = #{staffCode}</if>
            <if test="staffName != null  and staffName != ''"> and staff_name like concat('%', #{staffName}, '%')</if>
            <if test="gender != null "> and gender = #{gender}</if>
            <if test="birthDate != null "> and birth_date = #{birthDate}</if>
            <if test="orgId != null "> and org_id = #{orgId}</if>
            <if test="department != null  and department != ''"> and department = #{department}</if>
            <if test="jobTitle != null  and jobTitle != ''"> and job_title = #{jobTitle}</if>
            <if test="jobCategory != null  and jobCategory != ''"> and job_category = #{jobCategory}</if>
            <if test="education != null  and education != ''"> and education = #{education}</if>
            <if test="isActive != null "> and is_active = #{isActive}</if>
            <if test="entryDate != null "> and entry_date = #{entryDate}</if>
            <if test="createdAt != null "> and created_at = #{createdAt}</if>
            <if test="updatedAt != null "> and updated_at = #{updatedAt}</if>
        </where>
    </select>
    
    <select id="selectMedicalStaffById" parameterType="Long" resultMap="MedicalStaffResult">
        <include refid="selectMedicalStaffVo"/>
        where id = #{id}
    </select>

    <insert id="insertMedicalStaff" parameterType="MedicalStaff" useGeneratedKeys="true" keyProperty="id">
        insert into medical_staff
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="staffCode != null and staffCode != ''">staff_code,</if>
            <if test="staffName != null and staffName != ''">staff_name,</if>
            <if test="gender != null">gender,</if>
            <if test="birthDate != null">birth_date,</if>
            <if test="orgId != null">org_id,</if>
            <if test="department != null">department,</if>
            <if test="jobTitle != null">job_title,</if>
            <if test="jobCategory != null">job_category,</if>
            <if test="education != null">education,</if>
            <if test="isActive != null">is_active,</if>
            <if test="entryDate != null">entry_date,</if>
            <if test="createdAt != null">created_at,</if>
            <if test="updatedAt != null">updated_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="staffCode != null and staffCode != ''">#{staffCode},</if>
            <if test="staffName != null and staffName != ''">#{staffName},</if>
            <if test="gender != null">#{gender},</if>
            <if test="birthDate != null">#{birthDate},</if>
            <if test="orgId != null">#{orgId},</if>
            <if test="department != null">#{department},</if>
            <if test="jobTitle != null">#{jobTitle},</if>
            <if test="jobCategory != null">#{jobCategory},</if>
            <if test="education != null">#{education},</if>
            <if test="isActive != null">#{isActive},</if>
            <if test="entryDate != null">#{entryDate},</if>
            <if test="createdAt != null">#{createdAt},</if>
            <if test="updatedAt != null">#{updatedAt},</if>
         </trim>
    </insert>

    <update id="updateMedicalStaff" parameterType="MedicalStaff">
        update medical_staff
        <trim prefix="SET" suffixOverrides=",">
            <if test="staffCode != null and staffCode != ''">staff_code = #{staffCode},</if>
            <if test="staffName != null and staffName != ''">staff_name = #{staffName},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="birthDate != null">birth_date = #{birthDate},</if>
            <if test="orgId != null">org_id = #{orgId},</if>
            <if test="department != null">department = #{department},</if>
            <if test="jobTitle != null">job_title = #{jobTitle},</if>
            <if test="jobCategory != null">job_category = #{jobCategory},</if>
            <if test="education != null">education = #{education},</if>
            <if test="isActive != null">is_active = #{isActive},</if>
            <if test="entryDate != null">entry_date = #{entryDate},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteMedicalStaffById" parameterType="Long">
        delete from medical_staff where id = #{id}
    </delete>

    <delete id="deleteMedicalStaffByIds" parameterType="String">
        delete from medical_staff where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- ====== 统计分析查询 ====== -->

    <!-- 按职称分布 -->
    <select id="selectStaffJobTitleDistribution" resultType="java.util.Map">
        select job_title as name, count(*) as value
        from medical_staff
        where is_active = 1
        <if test="orgId != null"> and org_id = #{orgId} </if>
        group by job_title
        order by value desc
    </select>

    <!-- 按职业类别分布 -->
    <select id="selectStaffCategoryDistribution" resultType="java.util.Map">
        select job_category as name, count(*) as value
        from medical_staff
        where is_active = 1
        <if test="orgId != null"> and org_id = #{orgId} </if>
        group by job_category
        order by value desc
    </select>

    <!-- 按学历分布 -->
    <select id="selectStaffEducationDistribution" resultType="java.util.Map">
        select education as name, count(*) as value
        from medical_staff
        where is_active = 1
        <if test="orgId != null"> and org_id = #{orgId} </if>
        group by education
        order by value desc
    </select>

    <!-- 人员性别比例 -->
    <select id="selectStaffGenderRatio" resultType="java.util.Map">
        select
            case when gender = 1 then '男' when gender = 2 then '女' else '未知' end as name,
            count(*) as value
        from medical_staff
        where is_active = 1
        <if test="orgId != null"> and org_id = #{orgId} </if>
        group by gender
    </select>

    <!-- 人员总览统计 -->
    <select id="selectStaffSummary" resultType="java.util.Map">
        select
            count(*) as totalStaff,
            count(distinct job_title) as titleCount,
            count(distinct job_category) as categoryCount,
            count(distinct department) as deptCount,
            sum(case when is_active = 1 then 1 else 0 end) as activeCount
        from medical_staff
        <where>
            <if test="orgId != null"> and org_id = #{orgId} </if>
        </where>
    </select>

    <!-- 人员数量变化趋势 -->
    <select id="selectStaffTrend" resultType="java.util.Map">
        select date_format(created_at, '%Y') as year, count(*) as value
        from medical_staff
        group by date_format(created_at, '%Y')
        order by year
    </select>

</mapper>