<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.MedicalInstitutionMapper">
    
    <resultMap type="MedicalInstitution" id="MedicalInstitutionResult">
        <result property="id"    column="id"    />
        <result property="orgCode"    column="org_code"    />
        <result property="orgName"    column="org_name"    />
        <result property="orgType"    column="org_type"    />
        <result property="orgLevel"    column="org_level"    />
        <result property="regionId"    column="region_id"    />
        <result property="address"    column="address"    />
        <result property="contactPhone"    column="contact_phone"    />
        <result property="isActive"    column="is_active"    />
        <result property="establishedDate"    column="established_date"    />
        <result property="createdAt"    column="created_at"    />
        <result property="updatedAt"    column="updated_at"    />
    </resultMap>

    <sql id="selectMedicalInstitutionVo">
        select id, org_code, org_name, org_type, org_level, region_id, address, contact_phone, is_active, established_date, created_at, updated_at from medical_institution
    </sql>

    <select id="selectMedicalInstitutionList" parameterType="MedicalInstitution" resultMap="MedicalInstitutionResult">
        <include refid="selectMedicalInstitutionVo"/>
        <where>  
            <if test="orgCode != null  and orgCode != ''"> and org_code = #{orgCode}</if>
            <if test="orgName != null  and orgName != ''"> and org_name like concat('%', #{orgName}, '%')</if>
            <if test="orgType != null  and orgType != ''"> and org_type = #{orgType}</if>
            <if test="orgLevel != null  and orgLevel != ''"> and org_level = #{orgLevel}</if>
            <if test="regionId != null "> and region_id = #{regionId}</if>
            <if test="address != null  and address != ''"> and address = #{address}</if>
            <if test="contactPhone != null  and contactPhone != ''"> and contact_phone = #{contactPhone}</if>
            <if test="isActive != null "> and is_active = #{isActive}</if>
            <if test="establishedDate != null "> and established_date = #{establishedDate}</if>
            <if test="createdAt != null "> and created_at = #{createdAt}</if>
            <if test="updatedAt != null "> and updated_at = #{updatedAt}</if>
        </where>
    </select>
    
    <select id="selectMedicalInstitutionById" parameterType="Long" resultMap="MedicalInstitutionResult">
        <include refid="selectMedicalInstitutionVo"/>
        where id = #{id}
    </select>

    <insert id="insertMedicalInstitution" parameterType="MedicalInstitution" useGeneratedKeys="true" keyProperty="id">
        insert into medical_institution
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orgCode != null and orgCode != ''">org_code,</if>
            <if test="orgName != null and orgName != ''">org_name,</if>
            <if test="orgType != null and orgType != ''">org_type,</if>
            <if test="orgLevel != null">org_level,</if>
            <if test="regionId != null">region_id,</if>
            <if test="address != null">address,</if>
            <if test="contactPhone != null">contact_phone,</if>
            <if test="isActive != null">is_active,</if>
            <if test="establishedDate != null">established_date,</if>
            <if test="createdAt != null">created_at,</if>
            <if test="updatedAt != null">updated_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orgCode != null and orgCode != ''">#{orgCode},</if>
            <if test="orgName != null and orgName != ''">#{orgName},</if>
            <if test="orgType != null and orgType != ''">#{orgType},</if>
            <if test="orgLevel != null">#{orgLevel},</if>
            <if test="regionId != null">#{regionId},</if>
            <if test="address != null">#{address},</if>
            <if test="contactPhone != null">#{contactPhone},</if>
            <if test="isActive != null">#{isActive},</if>
            <if test="establishedDate != null">#{establishedDate},</if>
            <if test="createdAt != null">#{createdAt},</if>
            <if test="updatedAt != null">#{updatedAt},</if>
         </trim>
    </insert>

    <update id="updateMedicalInstitution" parameterType="MedicalInstitution">
        update medical_institution
        <trim prefix="SET" suffixOverrides=",">
            <if test="orgCode != null and orgCode != ''">org_code = #{orgCode},</if>
            <if test="orgName != null and orgName != ''">org_name = #{orgName},</if>
            <if test="orgType != null and orgType != ''">org_type = #{orgType},</if>
            <if test="orgLevel != null">org_level = #{orgLevel},</if>
            <if test="regionId != null">region_id = #{regionId},</if>
            <if test="address != null">address = #{address},</if>
            <if test="contactPhone != null">contact_phone = #{contactPhone},</if>
            <if test="isActive != null">is_active = #{isActive},</if>
            <if test="establishedDate != null">established_date = #{establishedDate},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteMedicalInstitutionById" parameterType="Long">
        delete from medical_institution where id = #{id}
    </delete>

    <delete id="deleteMedicalInstitutionByIds" parameterType="String">
        delete from medical_institution where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>